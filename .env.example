# brother-scan-to-paperless configuration reference
# The daemon reads JSON config from:
#   /etc/brother-scan-to-paperless/config.json (system)
#   ~/.config/brother-scan-to-paperless/config.json (user)
# Or run: brother-scan-to-paperless setup

# Required
SCANNER_IP=192.168.1.x
CONSUME_FOLDER=/path/to/paperless/consume

# Optional (defaults shown)
# DEVICE_NAME=brother4:net1;dev0
# RESOLUTION=300
# FORMAT=tiff
# PAPER_SIZE=A4
# LISTEN_PORT=54925
# REGISTRATION_INTERVAL=300
